APP_NAME="Vierdaagse Kesteren"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

# Domeinen (voor routes/redirects)
INSCHRIJVEN_DOMAIN=localhost
INTOUCH_DOMAIN=localhost
SCANNER_DOMAIN=localhost
# Wachtwoord-herstellink: basis-URL voor Intouch (indien anders dan APP_URL)
# INTOUCH_PASSWORD_RESET_URL=https://intouch.vierdaagsekesteren.nl

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Voor MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=vierdaagse
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mollie (betalingen inschrijven + sponsors)
MOLLIE_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOKS_ENABLED=false
# MOLLIE_WEBHOOKS_PATH=/webhooks/mollie
# MOLLIE_WEBHOOK_SIGNING_SECRETS=whsec_xxx

# Sponsors (vrienden) – doelbedrag, redirect na betaling, webhook
SPONSORS_DOELBEDRAG=1850
SPONSORS_REDIRECT_URL=https://vierdaagsekesteren.nl/vrienden-van-de-vierdaagse-kesteren/aanmelden/bedankt-voor-uw-bijdrage/
# Optioneel: volledige webhook-URL (anders: APP_URL + SPONSORS_WEBHOOK_PATH)
# SPONSORS_WEBHOOK_URL=https://inschrijven.vierdaagsekesteren.nl/webhooks/mollie/sponsors
SPONSORS_RECEIPT_BCC=mail@vierdaagsekesteren.nl

# Microsoft Graph (Intouch-login)
MSGRAPH_TENANT_ID=
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_SENDER_ADDRESS=

# Scanner: minimum minuten tussen twee scans op hetzelfde punt
SCANNER_MIN_MINUTES_BETWEEN_SCANS=5

# PDF ticket: noodnummers (komma-gescheiden)
APP_NOODNUMMERS="06 52 44 16 10, 06 40 89 37 40"
